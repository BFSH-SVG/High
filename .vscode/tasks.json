{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++ 编译当前文件",
            "type": "shell",
            "command": "/usr/bin/g++",
            "args": [
                "-std=c++17",
                "-g",
                "${relativeFile}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake 构建项目",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "cd '${workspaceFolder}' && rm -rf build && mkdir -p build && cd build && cmake .. && make"
            ],
            "group": "build",
            "problemMatcher": []
        }
    ]
}
